// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

enum OrderStatus {
  pending
  created
  updated
  shipped
  canceled
}

model Order {
  guid                String      @id @default(uuid())
  status              OrderStatus @default(pending)
  tracking_number     String?
  partnerOrderId      String      @unique
  comment             String?     @db.Text
  deliveryAddressType String
  cashOnDelivery      Float       @default(0)
  deliveryCompanyName String
  deliveryAddressId   String
  customerName        String
  deliveryCity        String
  deliveryPhone       String
  deliveryStreet      String
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  orderFiles OrderFile[]
  orderItems OrderItem[]

  @@map("orders")
}

model OrderItem {
  id            String  @id @default(uuid())
  orderGuid     String
  supplier_code String
  RZ_code       Int
  quantity      Int
  price         Float
  SerialNumber  String? @db.Text

  order Order @relation(fields: [orderGuid], references: [guid], onDelete: Cascade)

  @@map("order_items")
}

model OrderFile {
  file_guid  String   @id @default(uuid())
  orderGuid  String
  filePath   String
  fileName   String
  uploadedAt DateTime @default(now())

  order Order @relation(fields: [orderGuid], references: [guid], onDelete: Cascade)

  @@map("order_files")
}

model RozetkaProduct {
  code     String  @id @unique
  RZ_code  Int?
  category String?
  brand    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("rozetka_products")
}
